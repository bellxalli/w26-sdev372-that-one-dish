###############################################################################
# SECTION 1: DISH GALLERY (Gallery.jsx)
###############################################################################

### Get All Dishes (Used in Gallery component)
GET http://localhost:3000/api/dishes


###############################################################################
# SECTION 2: ADD DISH (AddDish.jsx)
###############################################################################

### Add Dish (Restaurant Origin)
POST http://localhost:3000/api/dishes
Content-Type: application/json

{
  "dish_name": "Cheese Burger",
  "cuisine": "American",
  "dish_details": "Juicy burger with cheddar cheese",
  "restaurant_name": "That One Place",
  "restaurant_address": "123 Food Street, Seattle WA"
}


### Add Dish (Home Made)
POST http://localhost:3000/api/dishes
Content-Type: application/json

{
  "dish_name": "Homemade Pasta",
  "cuisine": "Italian",
  "dish_details": "Fresh pasta with homemade tomato sauce",
  "restaurant_name": "",
  "restaurant_address": ""
}


###############################################################################
# SECTION 3: ADD DISH WITH IMAGE (multipart)
###############################################################################

### Upload Dish With Image
POST http://localhost:3000/api/dishes
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="dish_name"

Pizza
--boundary
Content-Disposition: form-data; name="cuisine"

Italian
--boundary
Content-Disposition: form-data; name="dish_details"

Wood fired pizza with basil and mozzarella
--boundary
Content-Disposition: form-data; name="restaurant_name"

Luigi's
--boundary
Content-Disposition: form-data; name="restaurant_address"

456 Italy Ave
--boundary
Content-Disposition: form-data; name="image"; filename="pizza.jpg"
Content-Type: image/jpeg

< ./pizza.jpg
--boundary--


###############################################################################
# SECTION 4: VERIFY GALLERY UPDATE
###############################################################################

### Check dishes again to confirm new entry appears
GET http://localhost:3000/api/dishes


###############################################################################
# SECTION 5: UPDATE A DISH
###############################################################################

### Update a Dish by ID (replace 1 with the actual dish ID)
PUT http://localhost:3000/api/dishes/1
Content-Type: application/json

{
  "dish_name": "Cheese Burger Deluxe",
  "cuisine": "American",
  "dish_details": "Juicy burger with cheddar cheese and bacon",
  "restaurant_name": "That One Place",
  "restaurant_address": "123 Food Street, Seattle WA"
}


###############################################################################
# SECTION 6: DELETE UPLOADED IMAGES
###############################################################################

### Delete a Single Uploaded Image (replace filename with actual file)
DELETE http://localhost:3000/api/dishes/uploads/pizza.jpg

### Delete All Uploaded Images
DELETE http://localhost:3000/api/dishes/uploads


###############################################################################
# SECTION 7: DELETE DISHES
###############################################################################

### Delete a Dish by ID (replace 1 with the actual dish ID)
DELETE http://localhost:3000/api/dishes/1

### Delete All Dishes
DELETE http://localhost:3000/api/dishes